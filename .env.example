# -----------------------------------------------------------------
#  PetQR — Variables de entorno
#  Copia este archivo como ".env" y rellena tus propios valores
# -----------------------------------------------------------------

# Base de datos (SQLite para desarrollo local)
DATABASE_URL=sqlite:///database.db

# Flask
FLASK_APP=src/app.py
FLASK_APP_KEY="cambia-esto-por-una-clave-secreta"
FLASK_DEBUG=1
DEBUG=TRUE

# JWT — clave secreta para firmar los tokens de autenticacion
JWT_SECRET_KEY=cambia-esto-por-una-clave-segura

# Cloudinary — para subir imagenes de mascotas
# Registrate gratis en https://cloudinary.com y copia tu "API Environment variable"
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://TU_API_KEY:TU_API_SECRET@TU_CLOUD_NAME

# Front-End
VITE_BASENAME=/
VITE_BACKEND_URL=http://127.0.0.1:3001
